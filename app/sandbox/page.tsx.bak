"use client";

import React, { useState, useCallback, useRef, useEffect } from "react";

// ============================================================================
// Types
// ============================================================================

interface TrainingLogEntry {
  step: number;
  loss: number;
  elapsed: number;
}

interface TrainResult {
  success: boolean;
  total_steps: number;
  final_loss: number;
  training_time_seconds: number;
  parameters: number;
  vocab_size: number;
  training_log: TrainingLogEntry[];
  error?: string;
}

interface GenerationStep {
  step: number;
  chosen_token: string;
  chosen_probability: number;
  top5_predictions: { token: string; probability: number }[];
}

interface GenerateResult {
  prompt: string;
  generated_text: string;
  total_tokens: number;
  steps: GenerationStep[];
  error?: string;
}

interface EmbeddingToken {
  token: string;
  x: number;
  y: number;
  embedding_norm: number;
}

interface EmbeddingsResult {
  vocab_size: number;
  d_model: number;
  tokens: EmbeddingToken[];
}

interface AttentionHead {
  layer: number;
  head: number;
  attention_matrix: number[][];
}

interface AttentionResult {
  n_layers: number;
  n_heads: number;
  attention_heads: AttentionHead[];
}

interface ModelInfo {
  loaded: boolean;
  parameters?: number;
  config?: {
    vocab_size: number;
    d_model: number;
    n_heads: number;
    n_layers: number;
    d_ff: number;
    context_length: number;
  };
  training_steps?: number;
  final_loss?: number;
  architecture?: Record<string, string>;
}

// ============================================================================
// API Helpers
// ============================================================================

const API_BASE = "/api/mini-gpt";

async function apiGet(endpoint: string) {
  const res = await fetch(`${API_BASE}?endpoint=${encodeURIComponent(endpoint)}`);
  if (!res.ok) {
    const err = await res.json().catch(() => ({ error: "Request failed" }));
    throw new Error(err.error || "API request failed");
  }
  return res.json();
}

async function apiPost(endpoint: string, body: Record<string, unknown>) {
  const res = await fetch(`${API_BASE}?endpoint=${encodeURIComponent(endpoint)}`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(body),
  });
  if (!res.ok) {
    const err = await res.json().catch(() => ({ error: "Request failed" }));
    throw new Error(err.error || "API request failed");
  }
  return res.json();
}

// ============================================================================
// Visualization Components
// ============================================================================

function LossChart({ log }: { log: TrainingLogEntry[] }) {
  const canvasRef = useRef<HTMLCanvasElement>(null);

  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas || log.length === 0) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const width = 600;
    const height = 200;
    canvas.width = width;
    canvas.height = height;

    ctx.clearRect(0, 0, width, height);

    const maxLoss = Math.max(...log.map((e) => e.loss));
    const minLoss = Math.min(...log.map((e) => e.loss));
    const range = maxLoss - minLoss || 1;

    // Grid lines
    ctx.strokeStyle = "rgba(255,255,255,0.06)";
    ctx.lineWidth = 1;
    for (let i = 0; i <= 4; i++) {
      const y = (i / 4) * height;
      ctx.beginPath();
      ctx.moveTo(0, y);
      ctx.lineTo(width, y);
      ctx.stroke();
    }

    // Loss curve
    ctx.strokeStyle = "#10a3f9";
    ctx.lineWidth = 2;
    ctx.beginPath();
    log.forEach((entry, i) => {
      const x = (i / (log.length - 1)) * width;
      const y = height - ((entry.loss - minLoss) / range) * (height - 20) - 10;
      if (i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    });
    ctx.stroke();
  }, [log]);

  return <canvas ref={canvasRef} style={{ width: "100%", height: "200px", borderRadius: "4px" }} />;
}

function AttentionHeatmap({ matrix, size }: { matrix: number[][]; size: number }) {
  const canvasRef = useRef<HTMLCanvasElement>(null);

  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas || matrix.length === 0) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const n = matrix.length;
    const cellSize = Math.floor(size / n);
    canvas.width = cellSize * n;
    canvas.height = cellSize * n;

    ctx.clearRect(0, 0, canvas.width, canvas.height);

    for (let i = 0; i < n; i++) {
      for (let j = 0; j < n; j++) {
        const val = matrix[i][j];
        ctx.fillStyle = `rgba(16, 163, 249, ${val})`;
        ctx.fillRect(j * cellSize, i * cellSize, cellSize - 1, cellSize - 1);
      }
    }
  }, [matrix, size]);

  return <canvas ref={canvasRef} style={{ borderRadius: "4px" }} />;
}

function EmbeddingPlot({ tokens }: { tokens: EmbeddingToken[] }) {
  const canvasRef = useRef<HTMLCanvasElement>(null);

  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas || tokens.length === 0) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const width = 600;
    const height = 400;
    canvas.width = width;
    canvas.height = height;

    ctx.clearRect(0, 0, width, height);
    ctx.fillStyle = "rgba(10,10,10,0.5)";
    ctx.fillRect(0, 0, width, height);

    const xs = tokens.map((t) => t.x);
    const ys = tokens.map((t) => t.y);
    const minX = Math.min(...xs), maxX = Math.max(...xs);
    const minY = Math.min(...ys), maxY = Math.max(...ys);
    const rangeX = maxX - minX || 1;
    const rangeY = maxY - minY || 1;
    const pad = 40;

    tokens.forEach((token) => {
      const px = pad + ((token.x - minX) / rangeX) * (width - 2 * pad);
      const py = pad + ((token.y - minY) / rangeY) * (height - 2 * pad);

      ctx.beginPath();
      ctx.arc(px, py, 4, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(168, 85, 247, ${0.3 + token.embedding_norm * 0.7})`;
      ctx.fill();

      ctx.fillStyle = "rgba(255,255,255,0.7)";
      ctx.font = "10px monospace";
      ctx.fillText(token.token === " " ? "⎵" : token.token, px + 6, py + 3);
    });
  }, [tokens]);

  return <canvas ref={canvasRef} style={{ width: "100%", height: "400px", borderRadius: "4px" }} />;
}

function AtomicKarpathyGPT() {
  const [status, setStatus] = useState<"idle" | "training" | "generating" | "error">("idle");
  const [trainResult, setTrainResult] = useState<{ loss: number; message: string } | null>(null);
  const [genResult, setGenResult] = useState<string>("");
  const [prompt, setPrompt] = useState("To be");
  const [error, setError] = useState<string | null>(null);

  const handleTrain = async () => {
    setStatus("training");
    setError(null);
    try {
      const res = await fetch("/api/mini-gpt-karpathy", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ endpoint: "train" }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || "Training failed");
      setTrainResult(data);
      setStatus("idle");
    } catch (e: any) {
      setError(e.message);
      setStatus("error");
    }
  };

  const handleGenerate = async () => {
    setStatus("generating");
    setError(null);
    try {
      const res = await fetch("/api/mini-gpt-karpathy", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ endpoint: "generate", prompt, max_new_tokens: 100 }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || "Generation failed");
      setGenResult(data.generated_text || data.text || "");
      setStatus("idle");
    } catch (e: any) {
      setError(e.message);
      setStatus("error");
    }
  };

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: "1rem" }}>
      <p style={{ fontSize: "0.85rem", color: "var(--text-secondary)" }}>
        A minimal character-level GPT following Karpathy&apos;s approach. Train on a small dataset, then generate text.
      </p>

      <div style={{ display: "flex", gap: "0.5rem" }}>
        <button
          onClick={handleTrain}
          disabled={status === "training"}
          style={{
            padding: "0.6rem 1.25rem",
            background: status === "training" ? "var(--bg-tertiary)" : "var(--gradient-primary)",
            border: "none",
            borderRadius: "var(--radius-md)",
            color: "white",
            fontWeight: 600,
            cursor: status === "training" ? "not-allowed" : "pointer",
            fontSize: "0.85rem",
          }}
        >
          {status === "training" ? "⏳ Training..." : "🏋️ Train"}
        </button>
      </div>

      {trainResult && (
        <div style={{ padding: "0.75rem", background: "var(--bg-secondary)", borderRadius: "var(--radius-md)", border: "1px solid var(--border-subtle)", fontSize: "0.8rem" }}>
          <span style={{ color: "var(--accent-blue)" }}>Loss: {typeof trainResult.loss === "number" ? trainResult.loss.toFixed(4) : trainResult.loss}</span>
          {trainResult.message && <span style={{ color: "var(--text-secondary)", marginLeft: "0.5rem" }}>— {trainResult.message}</span>}
        </div>
      )}

      <div style={{ display: "flex", gap: "0.5rem", alignItems: "center" }}>
        <input
          value={prompt}
          onChange={(e) => setPrompt(e.target.value)}
          placeholder="Seed text..."
          style={{
            flex: 1,
            padding: "0.5rem 0.6rem",
            background: "var(--bg-input)",
            border: "1px solid var(--border-subtle)",
            borderRadius: "var(--radius-sm)",
            color: "var(--text-primary)",
            fontSize: "0.8rem",
            fontFamily: "var(--font-mono)",
          }}
        />
        <button
          onClick={handleGenerate}
          disabled={status === "generating"}
          style={{
            padding: "0.6rem 1.25rem",
            background: status === "generating" ? "var(--bg-tertiary)" : "var(--gradient-primary)",
            border: "none",
            borderRadius: "var(--radius-md)",
            color: "white",
            fontWeight: 600,
            cursor: status === "generating" ? "not-allowed" : "pointer",
            fontSize: "0.85rem",
          }}
        >
          {status === "generating" ? "..." : "✨ Generate"}
        </button>
      </div>

      {genResult && (
        <div style={{
          padding: "0.75rem",
          background: "var(--bg-primary)",
          borderRadius: "var(--radius-sm)",
          fontFamily: "var(--font-mono)",
          fontSize: "0.85rem",
          lineHeight: 1.7,
          color: "var(--text-primary)",
          whiteSpace: "pre-wrap",
          wordBreak: "break-word",
        }}>
          {genResult}
        </div>
      )}

      {error && (
        <div style={{ padding: "0.5rem 0.75rem", background: "rgba(239,68,68,0.1)", border: "1px solid rgba(239,68,68,0.3)", borderRadius: "var(--radius-md)", color: "#ef4444", fontSize: "0.8rem" }}>
          {error}
        </div>
      )}
    </div>
  );
}

// ============================================================================
// Main Sandbox Page
// ============================================================================

export default function SandboxPage() {
  // State
  const [serverStatus, setServerStatus] = useState<"checking" | "online" | "offline">("checking");
  const [modelInfo, setModelInfo] = useState<ModelInfo | null>(null);
  const [activeTab, setActiveTab] = useState<"train" | "generate" | "attention" | "embeddings" | "about" | "karpathy" | "study">("train");
  const [studyMode, setStudyMode] = useState("concept-refresh");
  const [studyTopic, setStudyTopic] = useState("");
  const [studyConstraints, setStudyConstraints] = useState({ bullets: true, sentences: 5, hints: true, rubric: true });
  const [studyPrompt, setStudyPrompt] = useState("");

  // Training state
  const [isTraining, setIsTraining] = useState(false);
  const [trainResult, setTrainResult] = useState<TrainResult | null>(null);
  const [trainConfig, setTrainConfig] = useState({
    dataset: "shakespeare",
    n_steps: 300,
    batch_size: 16,
    learning_rate: 0.001,
    context_length: 32,
    d_model: 64,
    n_heads: 4,
    n_layers: 2,
    d_ff: 128,
  });

  // Generation state
  const [genPrompt, setGenPrompt] = useState("");
  const [genTemp, setGenTemp] = useState(0.8);
  const [genMaxTokens, setGenMaxTokens] = useState(100);
  const [genResult, setGenResult] = useState<GenerateResult | null>(null);
  const [isGenerating, setIsGenerating] = useState(false);

  // Visualization state
  const [embeddings, setEmbeddings] = useState<EmbeddingsResult | null>(null);
  const [attention, setAttention] = useState<AttentionResult | null>(null);
  const [error, setError] = useState<string | null>(null);

  // Check server status on mount
  useEffect(() => {
    checkServer();
  }, []);

  const checkServer = useCallback(async () => {
    setServerStatus("checking");
    try {
      const data = await apiGet("");
      setServerStatus("online");
      const info = await apiGet("model-info");
      setModelInfo(info);
    } catch {
      setServerStatus("offline");
    }
  }, []);

  const handleTrain = useCallback(async () => {
    setIsTraining(true);
    setError(null);
    setTrainResult(null);
    try {
      const result = await apiPost("train", trainConfig);
      setTrainResult(result);
      const info = await apiGet("model-info");
      setModelInfo(info);
    } catch (e: any) {
      setError(e.message);
    } finally {
      setIsTraining(false);
    }
  }, [trainConfig]);

  const handleGenerate = useCallback(async () => {
    setIsGenerating(true);
    setError(null);
    try {
      const result = await apiPost("generate", {
        prompt: genPrompt,
        max_tokens: genMaxTokens,
        temperature: genTemp,
      });
      setGenResult(result);
    } catch (e: any) {
      setError(e.message);
    } finally {
      setIsGenerating(false);
    }
  }, [genPrompt, genMaxTokens, genTemp]);

  const loadEmbeddings = useCallback(async () => {
    setError(null);
    try {
      const data = await apiGet("embeddings");
      setEmbeddings(data);
    } catch (e: any) {
      setError(e.message);
    }
  }, []);

  const loadAttention = useCallback(async () => {
    setError(null);
    try {
      // First generate something to populate attention cache
      if (!genResult) {
        await apiPost("generate", { prompt: "To be", max_tokens: 20, temperature: 0.8 });
      }
      const data = await apiGet("attention");
      setAttention(data);
    } catch (e: any) {
      setError(e.message);
    }
  }, [genResult]);

  // ========================================================================
  // Render
  // ========================================================================

  return (
    <div className="app-container">
      {/* Header */}
      <header className="header">
        <div className="header-content" style={{ maxWidth: "1100px" }}>
          <div className="logo">
            <span className="logo-icon">🧪</span>
            <span className="logo-text">Mini GPT Lab</span>
            <span className="logo-badge" style={{
              background: "rgba(168, 85, 247, 0.15)",
              borderColor: "rgba(168, 85, 247, 0.3)",
              color: "#a855f7"
            }}>Sandbox</span>
          </div>
          <nav className="nav-links">
            <a href="/" className="nav-link">← Back to Study AI</a>
          </nav>
        </div>
      </header>

      <main className="main-content" style={{ maxWidth: "1100px" }}>
        {/* Hero */}
        <div className="hero-section" style={{ paddingBottom: "0.5rem" }}>
          <h1 className="hero-title" style={{ fontSize: "1.5rem" }}>
            Transformer Sandbox
          </h1>
          <p className="hero-subtitle" style={{ fontSize: "0.85rem" }}>
            A pure-NumPy GPT built from scratch. Train, visualize attention, explore embeddings.
          </p>
          <p style={{
            fontSize: "0.7rem",
            color: "var(--text-tertiary)",
            marginTop: "0.25rem",
            padding: "0.3rem 0.6rem",
            background: "rgba(168, 85, 247, 0.08)",
            borderRadius: "var(--radius-sm)",
            display: "inline-block",
          }}>
            ⚠️ Educational module — NOT connected to production AI (Groq/Ollama/RAG)
          </p>
        </div>

        {/* Server Status */}
        <div style={{
          display: "flex",
          alignItems: "center",
          gap: "0.75rem",
          padding: "0.75rem 1rem",
          background: "var(--bg-secondary)",
          border: `1px solid ${serverStatus === "online" ? "rgba(34,197,94,0.3)" : serverStatus === "offline" ? "rgba(239,68,68,0.3)" : "var(--border-subtle)"}`,
          borderRadius: "var(--radius-md)",
          marginBottom: "1rem",
        }}>
          <span style={{
            width: "8px",
            height: "8px",
            borderRadius: "50%",
            background: serverStatus === "online" ? "#22c55e" : serverStatus === "offline" ? "#ef4444" : "#eab308",
          }} />
          <span style={{ fontSize: "0.8rem", color: "var(--text-secondary)" }}>
            {serverStatus === "checking" && "Checking Mini GPT server..."}
            {serverStatus === "online" && `Server online${modelInfo?.loaded ? ` — ${modelInfo.parameters?.toLocaleString()} params, ${modelInfo.training_steps} steps trained` : " — no model loaded"}`}
            {serverStatus === "offline" && "Server offline — run: cd mini-gpt && pip install -r requirements.txt && python server.py"}
          </span>
          <button
            onClick={checkServer}
            style={{
              marginLeft: "auto",
              padding: "0.3rem 0.6rem",
              background: "var(--bg-tertiary)",
              border: "1px solid var(--border-subtle)",
              borderRadius: "var(--radius-sm)",
              color: "var(--text-secondary)",
              fontSize: "0.75rem",
              cursor: "pointer",
            }}
          >
            Refresh
          </button>
        </div>

        {/* Tabs */}
        <div style={{
          display: "flex",
          gap: "0.25rem",
          marginBottom: "1.25rem",
          borderBottom: "1px solid var(--border-subtle)",
          paddingBottom: "0",
        }}>
          {(["train", "generate", "attention", "embeddings", "karpathy", "study", "about"] as const).map((tab) => (
            <button
              key={tab}
              onClick={() => {
                setActiveTab(tab);
                if (tab === "embeddings" && !embeddings && modelInfo?.loaded) loadEmbeddings();
                if (tab === "attention" && !attention && modelInfo?.loaded) loadAttention();
              }}
              style={{
                padding: "0.6rem 1rem",
                background: activeTab === tab ? "var(--bg-tertiary)" : "transparent",
                border: "1px solid transparent",
                borderBottom: activeTab === tab ? "2px solid var(--accent-blue)" : "2px solid transparent",
                borderRadius: "var(--radius-sm) var(--radius-sm) 0 0",
                color: activeTab === tab ? "var(--text-primary)" : "var(--text-tertiary)",
                fontSize: "0.8rem",
                fontWeight: activeTab === tab ? 600 : 400,
                cursor: "pointer",
                textTransform: "capitalize",
                transition: "all 0.15s ease",
              }}
            >
              {tab === "train" && "🏋️ "}
              {tab === "generate" && "✨ "}
              {tab === "attention" && "👁️ "}
              {tab === "embeddings" && "📊 "}
              {tab === "karpathy" && "🧬 "}
              {tab === "study" && "🎯 "}
              {tab === "about" && "📖 "}
              {tab === "karpathy" ? "Atomic GPT" : tab === "study" ? "Study" : tab}
            </button>
          ))}
        </div>
        {/* ================================================================ */}
        {/* ATOMIC KARPATHY GPT TAB */}
        {/* ================================================================ */}
        {activeTab === "karpathy" && (
          <div style={{ display: "flex", flexDirection: "column", gap: "1.5rem" }}>
            <h2 style={{ fontSize: "1.1rem", color: "var(--accent-blue)", marginBottom: "0.5rem" }}>
              Atomic GPT (Karpathy)
            </h2>
            <AtomicKarpathyGPT />
          </div>
        )}

        {/* ================================================================ */}
        {/* STUDY (EXAM MODE) TAB */}
        {/* ================================================================ */}
        {activeTab === "study" && (
          <div style={{ display: "flex", flexDirection: "column", gap: "1rem" }}>
            <div style={{ padding: "1rem", background: "var(--bg-secondary)", borderRadius: "var(--radius-md)", border: "1px solid var(--border-subtle)" }}>
              <h3 style={{ color: "var(--accent-blue)", marginBottom: "0.5rem" }}>Exam Study Prompt Builder</h3>
              <p style={{ fontSize: "0.85rem", color: "var(--text-secondary)", marginBottom: "0.75rem" }}>
                Build a concise, exam-style prompt you can paste into the main AI. No training needed; focused on retrieval, hints, and rubric-aligned answers.
              </p>

              <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(240px, 1fr))", gap: "0.75rem" }}>
                <label style={{ display: "flex", flexDirection: "column", gap: "0.35rem" }}>
                  <span style={{ fontSize: "0.7rem", color: "var(--text-tertiary)", textTransform: "uppercase", letterSpacing: "0.05em" }}>Mode</span>
                  <select value={studyMode} onChange={(e) => setStudyMode(e.target.value)} style={inputStyle}>
                    <option value="concept-refresh">Concept Refresh</option>
                    <option value="formula-drill">Formula Drill</option>
                    <option value="past-paper">Past-Paper Style</option>
                    <option value="flashcards">Flashcards</option>
                    <option value="mistake-fix">Common Mistakes</option>
                  </select>
                </label>

                <label style={{ display: "flex", flexDirection: "column", gap: "0.35rem" }}>
                  <span style={{ fontSize: "0.7rem", color: "var(--text-tertiary)", textTransform: "uppercase", letterSpacing: "0.05em" }}>Topic / Chapter</span>
                  <input value={studyTopic} onChange={(e) => setStudyTopic(e.target.value)} placeholder="e.g., Photosynthesis, Derivatives, WWII causes" style={inputStyle} />
                </label>

                <label style={{ display: "flex", flexDirection: "column", gap: "0.35rem" }}>
                  <span style={{ fontSize: "0.7rem", color: "var(--text-tertiary)", textTransform: "uppercase", letterSpacing: "0.05em" }}>Answer length (sentences)</span>
                  <input type="number" min={1} max={8} value={studyConstraints.sentences} onChange={(e) => setStudyConstraints({ ...studyConstraints, sentences: Number(e.target.value) })} style={inputStyle} />
                </label>

                <label style={{ display: "flex", alignItems: "center", gap: "0.5rem" }}>
                  <input type="checkbox" checked={studyConstraints.bullets} onChange={(e) => setStudyConstraints({ ...studyConstraints, bullets: e.target.checked })} />
                  <span style={{ fontSize: "0.8rem", color: "var(--text-secondary)" }}>Bullet-only answers</span>
                </label>

                <label style={{ display: "flex", alignItems: "center", gap: "0.5rem" }}>
                  <input type="checkbox" checked={studyConstraints.hints} onChange={(e) => setStudyConstraints({ ...studyConstraints, hints: e.target.checked })} />
                  <span style={{ fontSize: "0.8rem", color: "var(--text-secondary)" }}>Hint-first (reveal gradually)</span>
                </label>

                <label style={{ display: "flex", alignItems: "center", gap: "0.5rem" }}>
                  <input type="checkbox" checked={studyConstraints.rubric} onChange={(e) => setStudyConstraints({ ...studyConstraints, rubric: e.target.checked })} />
                  <span style={{ fontSize: "0.8rem", color: "var(--text-secondary)" }}>Rubric-style critique</span>
                </label>
              </div>

              <button
                onClick={() => setStudyPrompt(buildStudyPrompt(studyMode, studyTopic, studyConstraints))}
                style={{
                  marginTop: "0.75rem",
                  padding: "0.65rem 1.25rem",
                  background: "var(--gradient-primary)",
                  border: "none",
                  borderRadius: "var(--radius-md)",
                  color: "white",
                  fontWeight: 600,
                  cursor: "pointer",
                }}
              >
                Build Prompt
              </button>
            </div>

            {studyPrompt && (
              <div style={{ padding: "1rem", background: "var(--bg-secondary)", borderRadius: "var(--radius-md)", border: "1px solid var(--border-subtle)", fontFamily: "var(--font-mono)", fontSize: "0.9rem", whiteSpace: "pre-wrap" }}>
                {studyPrompt}
              </div>
            )}
          </div>
        )}

        {/* Error banner */}
        {error && (
          <div style={{
            padding: "0.75rem 1rem",
            background: "rgba(239, 68, 68, 0.1)",
            border: "1px solid rgba(239, 68, 68, 0.3)",
            borderRadius: "var(--radius-md)",
            color: "#ef4444",
            fontSize: "0.8rem",
            marginBottom: "1rem",
          }}>
            {error}
            <button
              onClick={() => setError(null)}
              style={{
                float: "right",
                background: "none",
                border: "none",
                color: "#ef4444",
                cursor: "pointer",
                fontSize: "0.9rem",
              }}
            >
              ✕
            </button>
          </div>
        )}

        {/* ================================================================ */}
        {/* TRAIN TAB */}
        {/* ================================================================ */}
        {activeTab === "train" && (
          <div style={{ display: "flex", flexDirection: "column", gap: "1rem" }}>
            {/* Config Grid */}
            <div style={{
              display: "grid",
              gridTemplateColumns: "repeat(auto-fill, minmax(200px, 1fr))",
              gap: "0.75rem",
              padding: "1rem",
              background: "var(--bg-secondary)",
              borderRadius: "var(--radius-md)",
              border: "1px solid var(--border-subtle)",
            }}>
              <label style={{ display: "flex", flexDirection: "column", gap: "0.3rem" }}>
                <span style={{ fontSize: "0.7rem", color: "var(--text-tertiary)", textTransform: "uppercase", letterSpacing: "0.05em" }}>Dataset</span>
                <select
                  value={trainConfig.dataset}
                  onChange={(e) => setTrainConfig({ ...trainConfig, dataset: e.target.value })}
                  style={inputStyle}
                >
                  <option value="shakespeare">Shakespeare</option>
                  <option value="science">Science</option>
                  <option value="patterns">Patterns</option>
                </select>
              </label>

              <label style={{ display: "flex", flexDirection: "column", gap: "0.3rem" }}>
                <span style={{ fontSize: "0.7rem", color: "var(--text-tertiary)", textTransform: "uppercase", letterSpacing: "0.05em" }}>Steps</span>
                <input
                  type="number"
                  value={trainConfig.n_steps}
                  onChange={(e) => setTrainConfig({ ...trainConfig, n_steps: Number(e.target.value) })}
                  min={10}
                  max={5000}
                  style={inputStyle}
                />
              </label>

              <label style={{ display: "flex", flexDirection: "column", gap: "0.3rem" }}>
                <span style={{ fontSize: "0.7rem", color: "var(--text-tertiary)", textTransform: "uppercase", letterSpacing: "0.05em" }}>Batch Size</span>
                <input
                  type="number"
                  value={trainConfig.batch_size}
                  onChange={(e) => setTrainConfig({ ...trainConfig, batch_size: Number(e.target.value) })}
                  min={1}
                  max={128}
                  style={inputStyle}
                />
              </label>

              <label style={{ display: "flex", flexDirection: "column", gap: "0.3rem" }}>
                <span style={{ fontSize: "0.7rem", color: "var(--text-tertiary)", textTransform: "uppercase", letterSpacing: "0.05em" }}>Learning Rate</span>
                <input
                  type="number"
                  value={trainConfig.learning_rate}
                  onChange={(e) => setTrainConfig({ ...trainConfig, learning_rate: Number(e.target.value) })}
                  min={0.0001}
                  max={1}
                  step={0.0001}
                  style={inputStyle}
                />
              </label>

              <label style={{ display: "flex", flexDirection: "column", gap: "0.3rem" }}>
                <span style={{ fontSize: "0.7rem", color: "var(--text-tertiary)", textTransform: "uppercase", letterSpacing: "0.05em" }}>d_model</span>
                <input
                  type="number"
                  value={trainConfig.d_model}
                  onChange={(e) => setTrainConfig({ ...trainConfig, d_model: Number(e.target.value) })}
                  min={16}
                  max={256}
                  step={16}
                  style={inputStyle}
                />
              </label>

              <label style={{ display: "flex", flexDirection: "column", gap: "0.3rem" }}>
                <span style={{ fontSize: "0.7rem", color: "var(--text-tertiary)", textTransform: "uppercase", letterSpacing: "0.05em" }}>Heads</span>
                <input
                  type="number"
                  value={trainConfig.n_heads}
                  onChange={(e) => setTrainConfig({ ...trainConfig, n_heads: Number(e.target.value) })}
                  min={1}
                  max={16}
                  style={inputStyle}
                />
              </label>

              <label style={{ display: "flex", flexDirection: "column", gap: "0.3rem" }}>
                <span style={{ fontSize: "0.7rem", color: "var(--text-tertiary)", textTransform: "uppercase", letterSpacing: "0.05em" }}>Layers</span>
                <input
                  type="number"
                  value={trainConfig.n_layers}
                  onChange={(e) => setTrainConfig({ ...trainConfig, n_layers: Number(e.target.value) })}
                  min={1}
                  max={8}
                  style={inputStyle}
                />
              </label>

              <label style={{ display: "flex", flexDirection: "column", gap: "0.3rem" }}>
                <span style={{ fontSize: "0.7rem", color: "var(--text-tertiary)", textTransform: "uppercase", letterSpacing: "0.05em" }}>d_ff</span>
                <input
                  type="number"
                  value={trainConfig.d_ff}
                  onChange={(e) => setTrainConfig({ ...trainConfig, d_ff: Number(e.target.value) })}
                  min={32}
                  max={512}
                  step={32}
                  style={inputStyle}
                />
              </label>

              <label style={{ display: "flex", flexDirection: "column", gap: "0.3rem" }}>
                <span style={{ fontSize: "0.7rem", color: "var(--text-tertiary)", textTransform: "uppercase", letterSpacing: "0.05em" }}>Context Length</span>
                <input
                  type="number"
                  value={trainConfig.context_length}
                  onChange={(e) => setTrainConfig({ ...trainConfig, context_length: Number(e.target.value) })}
                  min={8}
                  max={128}
                  step={8}
                  style={inputStyle}
                />
              </label>
            </div>

            {/* Train Button */}
            <button
              onClick={handleTrain}
              disabled={isTraining || serverStatus !== "online"}
              style={{
                padding: "0.75rem 1.5rem",
                background: isTraining ? "var(--bg-tertiary)" : "var(--gradient-primary)",
                border: "none",
                borderRadius: "var(--radius-md)",
                color: "white",
                fontSize: "0.875rem",
                fontWeight: 600,
                cursor: isTraining ? "not-allowed" : "pointer",
                opacity: serverStatus !== "online" ? 0.5 : 1,
                transition: "all 0.2s ease",
              }}
            >
              {isTraining ? "⏳ Training..." : "🚀 Train Model"}
            </button>

            {/* Training Results */}
            {trainResult && (
              <div style={{
                padding: "1rem",
                background: "var(--bg-secondary)",
                borderRadius: "var(--radius-md)",
                border: "1px solid var(--border-subtle)",
              }}>
                <div style={{
                  display: "flex",
                  justifyContent: "space-between",
                  marginBottom: "0.75rem",
                  flexWrap: "wrap",
                  gap: "0.5rem",
                }}>
                  <Stat label="Final Loss" value={trainResult.final_loss.toFixed(4)} color="#10a3f9" />
                  <Stat label="Parameters" value={trainResult.parameters.toLocaleString()} color="#a855f7" />
                  <Stat label="Vocab Size" value={String(trainResult.vocab_size)} color="#22c55e" />
                  <Stat label="Time" value={`${trainResult.training_time_seconds}s`} color="#eab308" />
                </div>
                <h3 style={{ fontSize: "0.8rem", color: "var(--text-secondary)", marginBottom: "0.5rem" }}>Training Loss</h3>
                <LossChart log={trainResult.training_log} />
              </div>
            )}
          </div>
        )}

        {/* ================================================================ */}
        {/* GENERATE TAB */}
        {/* ================================================================ */}
        {activeTab === "generate" && (
          <div style={{ display: "flex", flexDirection: "column", gap: "1rem" }}>
            <div style={{
              padding: "1rem",
              background: "var(--bg-secondary)",
              borderRadius: "var(--radius-md)",
              border: "1px solid var(--border-subtle)",
              display: "flex",
              flexDirection: "column",
              gap: "0.75rem",
            }}>
              <label style={{ display: "flex", flexDirection: "column", gap: "0.3rem" }}>
                <span style={{ fontSize: "0.7rem", color: "var(--text-tertiary)", textTransform: "uppercase", letterSpacing: "0.05em" }}>Prompt (seed text)</span>
                <input
                  type="text"
                  value={genPrompt}
                  onChange={(e) => setGenPrompt(e.target.value)}
                  placeholder="To be, or not to be"
                  style={{ ...inputStyle, width: "100%" }}
                />
              </label>

              <div style={{ display: "flex", gap: "0.75rem" }}>
                <label style={{ display: "flex", flexDirection: "column", gap: "0.3rem", flex: 1 }}>
                  <span style={{ fontSize: "0.7rem", color: "var(--text-tertiary)", textTransform: "uppercase", letterSpacing: "0.05em" }}>
                    Temperature: {genTemp.toFixed(2)}
                  </span>
                  <input
                    type="range"
                    min={0}
                    max={2}
                    step={0.05}
                    value={genTemp}
                    onChange={(e) => setGenTemp(Number(e.target.value))}
                    style={{ width: "100%" }}
                  />
                  <span style={{ fontSize: "0.65rem", color: "var(--text-muted)" }}>
                    0 = greedy → 1 = normal → 2 = creative
                  </span>
                </label>

                <label style={{ display: "flex", flexDirection: "column", gap: "0.3rem", width: "120px" }}>
                  <span style={{ fontSize: "0.7rem", color: "var(--text-tertiary)", textTransform: "uppercase", letterSpacing: "0.05em" }}>Max Tokens</span>
                  <input
                    type="number"
                    value={genMaxTokens}
                    onChange={(e) => setGenMaxTokens(Number(e.target.value))}
                    min={1}
                    max={500}
                    style={inputStyle}
                  />
                </label>
              </div>

              <button
                onClick={handleGenerate}
                disabled={isGenerating || serverStatus !== "online" || !modelInfo?.loaded}
                style={{
                  padding: "0.6rem 1.25rem",
                  background: isGenerating ? "var(--bg-tertiary)" : "var(--gradient-primary)",
                  border: "none",
                  borderRadius: "var(--radius-md)",
                  color: "white",
                  fontSize: "0.85rem",
                  fontWeight: 600,
                  cursor: isGenerating ? "not-allowed" : "pointer",
                  opacity: (!modelInfo?.loaded || serverStatus !== "online") ? 0.5 : 1,
                }}
              >
                {isGenerating ? "Generating..." : "✨ Generate"}
              </button>
            </div>

            {genResult && (
              <div style={{
                padding: "1rem",
                background: "var(--bg-secondary)",
                borderRadius: "var(--radius-md)",
                border: "1px solid var(--border-subtle)",
              }}>
                <h3 style={{ fontSize: "0.8rem", color: "var(--text-secondary)", marginBottom: "0.5rem" }}>Generated Text</h3>
                <div style={{
                  padding: "0.75rem",
                  background: "var(--bg-primary)",
                  borderRadius: "var(--radius-sm)",
                  fontFamily: "var(--font-mono)",
                  fontSize: "0.85rem",
                  lineHeight: 1.7,
                  color: "var(--text-primary)",
                  whiteSpace: "pre-wrap",
                  wordBreak: "break-word",
                  marginBottom: "0.75rem",
                }}>
                  <span style={{ color: "var(--accent-blue)" }}>{genResult.prompt}</span>
                  {genResult.generated_text.slice(genResult.prompt.length)}
                </div>

                <h3 style={{ fontSize: "0.8rem", color: "var(--text-secondary)", marginBottom: "0.5rem" }}>Token-by-Token Predictions (first 10)</h3>
                <div style={{ display: "flex", flexDirection: "column", gap: "0.25rem" }}>
                  {genResult.steps.slice(0, 10).map((step, i) => (
                    <div key={i} style={{
                      display: "flex",
                      alignItems: "center",
                      gap: "0.5rem",
                      padding: "0.3rem 0.5rem",
                      background: "var(--bg-primary)",
                      borderRadius: "var(--radius-sm)",
                      fontSize: "0.75rem",
                    }}>
                      <span style={{ color: "var(--text-muted)", width: "20px" }}>{step.step}</span>
                      <span style={{
                        fontFamily: "var(--font-mono)",
                        color: "var(--accent-blue)",
                        fontWeight: 600,
                        width: "30px",
                        textAlign: "center",
                      }}>
                        {step.chosen_token === " " ? "⎵" : step.chosen_token === "\n" ? "↵" : step.chosen_token}
                      </span>
                      <div style={{
                        flex: 1,
                        height: "6px",
                        background: "var(--bg-tertiary)",
                        borderRadius: "3px",
                        overflow: "hidden",
                      }}>
                        <div style={{
                          width: `${step.chosen_probability * 100}%`,
                          height: "100%",
                          background: "var(--accent-blue)",
                          borderRadius: "3px",
                        }} />
                      </div>
                      <span style={{ color: "var(--text-muted)", fontFamily: "var(--font-mono)", width: "45px", textAlign: "right" }}>
                        {(step.chosen_probability * 100).toFixed(1)}%
                      </span>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}

        {/* ================================================================ */}
        {/* ATTENTION TAB */}
        {/* ================================================================ */}
        {activeTab === "attention" && (
          <div style={{ display: "flex", flexDirection: "column", gap: "1rem" }}>
            <div style={{
              padding: "1rem",
              background: "var(--bg-secondary)",
              borderRadius: "var(--radius-md)",
              border: "1px solid var(--border-subtle)",
            }}>
              <p style={{ fontSize: "0.8rem", color: "var(--text-secondary)", marginBottom: "0.75rem" }}>
                Attention weights show how each token &quot;looks at&quot; other tokens.
                Brighter = more attention. Each head learns different patterns.
              </p>
              <button
                onClick={loadAttention}
                disabled={serverStatus !== "online" || !modelInfo?.loaded}
                style={{
                  padding: "0.5rem 1rem",
                  background: "var(--bg-tertiary)",
                  border: "1px solid var(--border-subtle)",
                  borderRadius: "var(--radius-md)",
                  color: "var(--text-primary)",
                  fontSize: "0.8rem",
                  cursor: "pointer",
                }}
              >
                🔄 Load Attention Weights
              </button>
            </div>

            {attention && (
              <div style={{
                display: "grid",
                gridTemplateColumns: "repeat(auto-fill, minmax(200px, 1fr))",
                gap: "0.75rem",
              }}>
                {attention.attention_heads.map((head, i) => (
                  <div key={i} style={{
                    padding: "0.75rem",
                    background: "var(--bg-secondary)",
                    borderRadius: "var(--radius-md)",
                    border: "1px solid var(--border-subtle)",
                  }}>
                    <p style={{ fontSize: "0.7rem", color: "var(--text-tertiary)", marginBottom: "0.5rem" }}>
                      Layer {head.layer} • Head {head.head}
                    </p>
                    <AttentionHeatmap matrix={head.attention_matrix} size={200} />
                  </div>
                ))}
              </div>
            )}
          </div>
        )}

        {/* ================================================================ */}
        {/* EMBEDDINGS TAB */}
        {/* ================================================================ */}
        {activeTab === "embeddings" && (
          <div style={{ display: "flex", flexDirection: "column", gap: "1rem" }}>
            <div style={{
              padding: "1rem",
              background: "var(--bg-secondary)",
              borderRadius: "var(--radius-md)",
              border: "1px solid var(--border-subtle)",
            }}>
              <p style={{ fontSize: "0.8rem", color: "var(--text-secondary)", marginBottom: "0.75rem" }}>
                Token embeddings projected to 2D via PCA. Similar tokens should cluster together as the model trains.
              </p>
              <button
                onClick={loadEmbeddings}
                disabled={serverStatus !== "online" || !modelInfo?.loaded}
                style={{
                  padding: "0.5rem 1rem",
                  background: "var(--bg-tertiary)",
                  border: "1px solid var(--border-subtle)",
                  borderRadius: "var(--radius-md)",
                  color: "var(--text-primary)",
                  fontSize: "0.8rem",
                  cursor: "pointer",
                }}
              >
                🔄 Load Embeddings
              </button>
            </div>

            {embeddings && (
              <div style={{
                padding: "1rem",
                background: "var(--bg-secondary)",
                borderRadius: "var(--radius-md)",
                border: "1px solid var(--border-subtle)",
              }}>
                <div style={{ display: "flex", gap: "1rem", marginBottom: "0.5rem" }}>
                  <Stat label="Vocab Size" value={String(embeddings.vocab_size)} color="#a855f7" />
                  <Stat label="Dimensions" value={String(embeddings.d_model)} color="#10a3f9" />
                </div>
                <EmbeddingPlot tokens={embeddings.tokens} />
              </div>
            )}
          </div>
        )}

        {/* ================================================================ */}
        {/* ABOUT TAB */}
        {/* ================================================================ */}
        {activeTab === "about" && (
          <div style={{
            padding: "1.25rem",
            background: "var(--bg-secondary)",
            borderRadius: "var(--radius-md)",
            border: "1px solid var(--border-subtle)",
            fontSize: "0.85rem",
            color: "var(--text-secondary)",
            lineHeight: 1.8,
          }}>
            <h2 style={{ color: "var(--text-primary)", marginBottom: "0.75rem", fontSize: "1.1rem" }}>
              About This Module
            </h2>

            <section style={{ marginBottom: "1.25rem" }}>
              <h3 style={{ color: "var(--accent-blue)", fontSize: "0.9rem", marginBottom: "0.5rem" }}>What Is This?</h3>
              <p>
                A <strong>complete GPT-style transformer</strong> implemented from scratch using only NumPy.
                Every operation — matrix multiply, softmax, attention, backpropagation — is written explicitly.
                No PyTorch, no TensorFlow.
              </p>
            </section>

            <section style={{ marginBottom: "1.25rem" }}>
              <h3 style={{ color: "var(--accent-blue)", fontSize: "0.9rem", marginBottom: "0.5rem" }}>Architecture</h3>
              <ul style={{ paddingLeft: "1.25rem" }}>
                <li><strong>Token Embeddings</strong> — Learned lookup table mapping characters to dense vectors</li>
                <li><strong>Sinusoidal Positional Encoding</strong> — Fixed encodings giving position information</li>
                <li><strong>Multi-Head Causal Self-Attention</strong> — The core mechanism. Q·K^T/√d_k computes which tokens to attend to</li>
                <li><strong>RMSNorm</strong> — Modern normalization (used in LLaMA). Simpler than LayerNorm: x/RMS(x)·γ</li>
                <li><strong>Feed-Forward Network</strong> — Two-layer MLP with GELU activation. Acts as a &quot;memory bank&quot;</li>
                <li><strong>Residual Connections</strong> — x + SubLayer(Norm(x)) to help gradient flow</li>
                <li><strong>Cross-Entropy Loss</strong> — Measures prediction quality: L = -Σ log P(correct)</li>
              </ul>
            </section>

            <section style={{ marginBottom: "1.25rem" }}>
              <h3 style={{ color: "var(--accent-blue)", fontSize: "0.9rem", marginBottom: "0.5rem" }}>How Attention Works</h3>
              <p>For each token, attention asks: &quot;Which other tokens should I pay attention to?&quot;</p>
              <div style={{
                padding: "0.75rem",
                background: "var(--bg-primary)",
                borderRadius: "var(--radius-sm)",
                fontFamily: "var(--font-mono)",
                fontSize: "0.8rem",
                margin: "0.5rem 0",
                color: "var(--accent-blue)",
              }}>
                Attention(Q, K, V) = softmax(Q·K<sup>T</sup> / √d_k) · V
              </div>
              <p>
                <strong>Q</strong> (Query) = &quot;What am I looking for?&quot;<br />
                <strong>K</strong> (Key) = &quot;What do I contain?&quot;<br />
                <strong>V</strong> (Value) = &quot;What information do I provide?&quot;
              </p>
            </section>

            <section style={{ marginBottom: "1.25rem" }}>
              <h3 style={{ color: "var(--accent-blue)", fontSize: "0.9rem", marginBottom: "0.5rem" }}>How Gradients Propagate</h3>
              <p>
                Backpropagation uses the chain rule to compute ∂Loss/∂θ for every parameter θ.
                Gradients flow backward through: output → transformer blocks → embeddings.
                Residual connections provide a &quot;gradient highway&quot; that prevents vanishing gradients
                in deep networks. RMSNorm stabilizes gradient magnitudes at each layer.
              </p>
            </section>

            <section style={{ marginBottom: "1rem", padding: "0.75rem", background: "rgba(168, 85, 247, 0.08)", borderRadius: "var(--radius-md)" }}>
              <h3 style={{ color: "#a855f7", fontSize: "0.9rem", marginBottom: "0.5rem" }}>⚠️ Isolation Notice</h3>
              <p>
                This sandbox is <strong>completely isolated</strong> from the production AI system.
              </p>
              <table style={{ width: "100%", borderCollapse: "collapse", marginTop: "0.5rem", fontSize: "0.8rem" }}>
                <thead>
                  <tr style={{ borderBottom: "1px solid var(--border-subtle)" }}>
                    <th style={{ textAlign: "left", padding: "0.4rem", color: "var(--text-tertiary)" }}>Aspect</th>
                    <th style={{ textAlign: "left", padding: "0.4rem", color: "var(--text-tertiary)" }}>This Sandbox</th>
                    <th style={{ textAlign: "left", padding: "0.4rem", color: "var(--text-tertiary)" }}>Production AI</th>
                  </tr>
                </thead>
                <tbody>
                  {[
                    ["Model", "~50K params (NumPy)", "70B params (Groq/Ollama)"],
                    ["Data", "Toy dataset (KB)", "Pretrained on TB"],
                    ["Purpose", "Education", "Inference"],
                    ["Embeddings", "Learned from scratch", "pgvector + OpenAI"],
                    ["Retrieval", "None", "RAG + Supabase"],
                    ["Training", "Seconds on CPU", "Weeks on GPU clusters"],
                  ].map(([aspect, sandbox, production], i) => (
                    <tr key={i} style={{ borderBottom: "1px solid var(--border-subtle)" }}>
                      <td style={{ padding: "0.4rem", fontWeight: 500 }}>{aspect}</td>
                      <td style={{ padding: "0.4rem" }}>{sandbox}</td>
                      <td style={{ padding: "0.4rem" }}>{production}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </section>
          </div>
        )}
      </main>
    </div>
  );
}

// ============================================================================
// Helper Components
// ============================================================================

function Stat({ label, value, color }: { label: string; value: string; color: string }) {
  return (
    <div style={{
      display: "flex",
      flexDirection: "column",
      gap: "0.15rem",
    }}>
      <span style={{ fontSize: "0.65rem", color: "var(--text-muted)", textTransform: "uppercase", letterSpacing: "0.05em" }}>{label}</span>
      <span style={{ fontSize: "1rem", fontWeight: 700, color, fontFamily: "var(--font-mono)" }}>{value}</span>
    </div>
  );
}

const inputStyle: React.CSSProperties = {
  padding: "0.5rem 0.6rem",
  background: "var(--bg-input)",
  border: "1px solid var(--border-subtle)",
  borderRadius: "var(--radius-sm)",
  color: "var(--text-primary)",
  fontSize: "0.8rem",
  fontFamily: "var(--font-mono)",
  outline: "none",
  width: "100%",
};

// (Karpathy component removed earlier since sandbox is prompt builder only)


function CopyPromptButton({ prompt }: { prompt: string }) {
  const [copied, setCopied] = useState(false);
  const handleCopy = async () => {
    try {
      await navigator.clipboard.writeText(prompt);
      setCopied(true);
      setTimeout(() => setCopied(false), 1500);
    } catch {
      setCopied(false);
    }
  };

  return (
    <button
      onClick={handleCopy}
      style={{
        position: "absolute",
        top: "8px",
        right: "16px",
        padding: "0.4rem 1rem",
        background: "var(--gradient-primary)",
        color: "white",
        border: "none",
        borderRadius: "var(--radius-sm)",
        fontWeight: 600,
        fontSize: "0.85rem",
        cursor: "pointer",
        boxShadow: "0 1px 4px rgba(0,0,0,0.04)",
        zIndex: 2,
      }}
    >
      {copied ? "Copied!" : "Copy to clipboard"}
    </button>
  );
}

function buildStudyPrompt(mode: string, topic: string, c: { bullets: boolean; sentences: number; hints: boolean; rubric: boolean }) {
  const topicText = topic?.trim() ? topic.trim() : "[insert your topic]";
  const parts: string[] = [];
  const modeText: Record<string, string> = {
    "concept-refresh": "Give a concise concept refresh",
    "formula-drill": "Drill formulas with 2 worked examples",
    "past-paper": "Generate 2 past-paper style questions with answers",
    "flashcards": "Create 6 flashcards",
    "mistake-fix": "List common mistakes and fixes",
  };
  parts.push(`${modeText[mode] || "Explain"} for ${topicText}.`);
  parts.push(`Limit to ${c.sentences} sentences${c.bullets ? ", bullet-only" : ""}.`);
  if (c.hints) parts.push("Reveal hints first, then full answer.");
  if (c.rubric) parts.push("Provide a brief rubric-style critique for a student attempt (clarity, correctness, conciseness).");
  parts.push("End with a one-line recap and 1 follow-up question.");
  return parts.join(" ");
}
